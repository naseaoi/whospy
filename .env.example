# Environment Configuration Example
# Copy this file to .env and adjust values as needed

# Server Port
PORT=3001

# CORS Origins (comma-separated, leave empty for default)
# Example: CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGIN=

# Timer Settings (in milliseconds)
# Time before cleaning up a room with all players offline
ROOM_RECONNECT_GRACE_MS=120000

# Time before transferring host to another online player
HOST_TRANSFER_GRACE_MS=30000

# Time before removing an offline player permanently
OFFLINE_PLAYER_REMOVE_MS=10000

# Node Environment
NODE_ENV=development
